# ── Home Assistant ────────────────────────────────────────────────────────────
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=your_long_lived_access_token
# SSH into HA (SSH & Web Terminal add-on) — used by deploy to write /config/www
HA_SSH_HOST=YOUR_HA_IP
HA_SSH_USER=hassio
HA_SSH_PASSWORD=your_password
# Remote dir served by HA at /local/eink/ (rarely needs changing)
#EINK_REMOTE_DIR=/config/www/eink

# ── B/W panel quirk ───────────────────────────────────────────────────────────
# Set 1 if your 1-bit panel firmware displays the PNG inverted (the TRMNL
# waveshare 7.50inv2 does): the device PNG is pre-inverted to cancel it out.
EINK_INVERT=1

# ── Photos (gallery / poster styles) ─────────────────────────────────────────
# bing = Bing daily wallpaper | nas = local dir | picsum = random | ai = generated
EINK_PHOTO_SOURCE=bing
# For nas: any mounted directory of images (searched recursively), e.g. an
# NFS/SMB mount from your NAS
#EINK_NAS_PHOTO_DIR=/mnt/fnOS/photos

# ── News (nothing / journal styles) ──────────────────────────────────────────
# Directory containing freshrss_bridge.py (optional; empty = no news)
#EINK_NEWS_BRIDGE_DIR=/root/ha/scripts/the_daily

# ── AI (claude / codex CLI) ───────────────────────────────────────────────────
# claude | codex | none; empty = auto-detect installed CLI
#EINK_AI_BACKEND=claude
#EINK_AI_TIMEOUT=180
# AI caption for gallery photos (1 = on; cached per photo)
#EINK_AI_CAPTION=1
# Custom image-gen command template for EINK_PHOTO_SOURCE=ai, e.g.
#EINK_IMAGEGEN_CMD=my-imagegen --prompt {prompt} --out {out}

# ── Style playlists per panel (cron rotates through these) ──────────────────
EINK_PLAYLIST_BW=nothing,gallery
EINK_PLAYLIST_E6=nothing,poster,gallery,journal
